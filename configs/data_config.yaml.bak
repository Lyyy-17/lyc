# 数据路径与清洗参数（相对项目根目录）
project:
  root: .

paths:
  raw:
    eddy: data/raw/eddy_detection
    element_forecasting: data/raw/element_forecasting
    anomaly: data/raw/anomaly_detection
  processed:
    eddy: data/processed/eddy_detection
    element_forecasting: data/processed/element_forecasting
    anomaly: data/processed/anomaly_detection
  splits: data/processed/splits
  normalization: data/processed/normalization

# 训练 / 验证 / 测试划分（基于 data/processed 下已清洗样本）
split:
  train_ratio: 0.7
  val_ratio: 0.15
  test_ratio: 0.15
  seed: 42

# 统计脚本：每类最多抽样文件数（0 表示不限制，仅取前若干由 max_files_per_task 控制）
stats:
  max_files_per_task: 5
  random_seed: 42

# 批处理：每任务最多处理文件数（调试用，null 表示全部）
batch:
  max_files_eddy: null
  max_files_element: null
  max_files_anomaly_years: null  # 每年 oper+wave 算 1 组

# NetCDF 缺测与哨兵值（与 data/raw 抽样读取一致）
fill:
  eddy_float: -2147483647.0
  element: -30000.0

# 输出 NetCDF 编码
output:
  compression: true
  complevel: 4
